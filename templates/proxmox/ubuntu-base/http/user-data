#cloud-config
autoinstall:
  version: 1
  identity:
    hostname: '{{hostname}}'
    password: '{{crypted_password}}'
    username: '{{username}}'
  network:
    network:
      version: 2
      ethernets:
        all-en:
          match:
            name: "en*"
          dhcp4: yes
          nameservers:
            addresses: [8.8.8.8, 1.1.1.1]
  ssh:
    install-server: true
  packages:
    - apt-transport-https
    - ca-certificates
    - curl
    - qemu-guest-agent
  late-commands:
    - curtin in-target -- systemctl enable qemu-guest-agent
    - echo '{{username}} ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/{{username}}

